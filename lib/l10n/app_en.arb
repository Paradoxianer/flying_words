  "impressumResponsibleTitle": "Responsible for content",
  "impressumResponsibleBody": "Unless a different party is named here, the provider named above under 'Provider' is responsible for content under German law (§ 18(2) MStV). This separate entry is only mandatory for editorial content with a certain reach.",
  "impressumDisputeTitle": "Dispute resolution",
  "impressumDisputeBody": "The European Commission provides a platform for online dispute resolution (ODR): https://ec.europa.eu/consumers/odr/. You can find our email address above under 'Contact'.\n\nWe are neither obliged nor willing to take part in dispute resolution proceedings before a consumer arbitration board.",
  "impressumLiabilityTitle": "Liability notice",
  "impressumLiabilityBody": "The Bible texts shown in this app are retrieved through the bolls.life interface. Despite careful review, we cannot guarantee the accuracy, completeness or timeliness of the translations. The operators of linked external sites (e.g. Google, Apple) are solely responsible for their own content.",

  "privacyPolicy": "Privacy Policy",
  "privacyOptions": "Ad privacy options",
  "privacyControllerTitle": "Data controller",
  "privacyControllerBody": "The controller responsible for data processing under the General Data Protection Regulation (GDPR) is:\n\n{name}\n{address}\n{email}",
  "@privacyControllerBody": {
    "placeholders": {
      "name": {"type": "String"},
